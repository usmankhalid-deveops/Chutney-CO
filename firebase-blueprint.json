{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account registration and role details",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin"] },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "MenuItem": {
      "title": "Menu Item",
      "description": "Restaurant menu item details including price and stock level",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "stock": { "type": "number" },
        "imageUrl": { "type": "string" },
        "isAvailable": { "type": "boolean" }
      },
      "required": ["id", "name", "category", "price", "stock", "isAvailable"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order details and status",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "recipientName": { "type": "string" },
        "recipientEmail": { "type": "string" },
        "recipientPhone": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "delivered", "cancelled"] },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "userId", "customerName", "customerEmail", "recipientName", "recipientEmail", "recipientPhone", "phone", "address", "items", "totalAmount", "paymentMethod", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Stores user registration profiles with roles"
    },
    "/menu/{itemId}": {
      "schema": "MenuItem",
      "description": "Stores food items on the restaurant menu"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Stores client orders"
    }
  }
}
